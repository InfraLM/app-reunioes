# ============================================================
# BANCO DE DADOS
# ============================================================
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# ============================================================
# AUTENTICAÇÃO
# ============================================================
JWT_SECRET="your-secret-key-here"

# ============================================================
# AMBIENTE
# ============================================================
NODE_ENV=production

# ============================================================
# GOOGLE CLOUD - SERVICE ACCOUNT (Domain-Wide Delegation)
# ============================================================
GOOGLE_PROJECT_ID="your-project-id"
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# E-mail do admin do Google Workspace (usado para chamadas ao Admin SDK Directory API)
IMPERSONATED_USER_EMAIL="admin@yourdomain.com"

# ============================================================
# USUÁRIOS MONITORADOS
# E-mails institucionais cujas reuniões serão rastreadas.
# Separados por vírgula, sem espaços.
# ============================================================
MONITORED_USERS="usuario1@empresa.com,usuario2@empresa.com"

# ============================================================
# GOOGLE PUB/SUB (Push Subscription)
# O tópico recebe os eventos do Google Workspace Events API.
# A Push Subscription aponta para: /api/webhooks/google-events
# ============================================================
PUBSUB_TOPIC_NAME="meet-events-topic"

# ============================================================
# WEBHOOK DE DESTINO
# Para onde enviar os dados das reuniões após o processamento.
# ============================================================
WEBHOOK_DESTINATION_URL="https://your-webhook-destination.com/endpoint"

# ============================================================
# CORS
# ============================================================
CORS_ORIGIN="http://localhost:3000,https://reuniao.lmedu.com.br"

# ============================================================
# ANTHROPIC (Chat IA)
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================================
# SEGURANÇA DO CRON
# Token para proteger o endpoint /api/cron/process-timeouts
# ============================================================
CRON_SECRET=your-cron-secret-token
