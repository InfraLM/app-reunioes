{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/cron/process-queue", "schedule": "* * * * *" }
  ],
  "rewrites": [
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/)(?!@)(?!__)(?!node_modules/)(?!src/)(?!assets/)(?!.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
